---
interface Props {
	title: string;
	url?: string;
}

const { title, url = Astro.url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url.href);
const farcasterShareUrl = `https://warpcast.com/~/compose?text=${encodedTitle}&embeds[]=${encodedUrl}`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
---

<div class="share-buttons">
	<span class="share-label">Share:</span>
	<a
		href={farcasterShareUrl}
		target="_blank"
		rel="noopener"
		class="share-button share-button--farcaster"
		aria-label="Share on Farcaster"
	>
		<span>Farcaster</span>
	</a>
	<a
		href={twitterShareUrl}
		target="_blank"
		rel="noopener"
		class="share-button share-button--twitter"
		aria-label="Share on Twitter"
	>
		<span>Twitter</span>
	</a>
	<button
		class="share-button share-button--copy"
		aria-label="Copy link"
		onclick={`navigator.clipboard.writeText('${url.href}').then(() => {
			const btn = event.target.closest('.share-button');
			const originalText = btn.querySelector('span').textContent;
			btn.querySelector('span').textContent = 'Copied!';
			setTimeout(() => btn.querySelector('span').textContent = originalText, 2000);
		});`}
	>
		<span>Copy</span>
	</button>
</div>

<style>
	.share-buttons {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 0;
		border-top: 1px solid var(--border);
		margin-top: 2rem;
	}

	.share-label {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-family: 'Space Mono', monospace;
	}

	.share-button {
		font-size: 0.85rem;
		padding: 0.4rem 0.75rem;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--bg-secondary);
		color: var(--text);
		text-decoration: none;
		cursor: pointer;
		transition: all 0.15s;
		font-family: 'Inter', sans-serif;
	}

	.share-button:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	.share-button--farcaster {
		border-color: #8b5cf6;
		color: #a78bfa;
	}

	.share-button--farcaster:hover {
		background: rgba(139, 92, 246, 0.1);
	}

	.share-button--twitter {
		border-color: #0ea5e9;
		color: #38bdf8;
	}

	.share-button--twitter:hover {
		background: rgba(14, 165, 233, 0.1);
	}

	@media (max-width: 640px) {
		.share-buttons {
			flex-wrap: wrap;
		}

		.share-label {
			width: 100%;
			margin-bottom: 0.5rem;
		}
	}
</style>
