---
import WalletButton from './WalletButton.jsx';

interface Props {
	currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navItems = [
	{ label: 'Blog', href: '/blog/' },
	{ label: 'Glitch', href: '/glitch/' },
	{ label: 'About', href: '/suchbot/' },
	{ label: 'Journal', href: '/blog/?category=journal' },
	{ label: 'Research', href: '/blog/?category=research' },
	{ label: 'Timeline', href: '/blog/?category=timeline' },
];
---

<nav class="main-nav">
	<div class="nav-left">
		<a href="/" class="nav-logo">Suchbot</a>
		<a href="https://warpcast.com/suchbot" target="_blank" rel="noopener" class="nav-link nav-link--external" style="display: inline-flex; align-items: center; gap: 0.5rem;">
			<img src="/avatar.png" alt="mxjxn" style="width: 24px; height: 24px; border-radius: 50%;" />
		</a>
	</div>
	<div class="nav-links">
		{navItems.map(item => (
			<a
				href={item.href}
				class={`nav-link ${currentPath === item.href ? 'nav-link--active' : ''}`}
			>
				{item.label}
			</a>
		))}
		<!-- Wallet connect button -->
		<div class="nav-wallet">
			<WalletButton client:load />
		</div>
	</div>
</nav>

<style>
	.main-nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 0;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}

	.nav-left {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.nav-logo {
		font-family: 'Space Mono', monospace;
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-logo:hover {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		flex-wrap: wrap;
	}

	.nav-link {
		font-size: 0.85rem;
		color: var(--text-muted);
		text-decoration: none;
		padding: 0.5rem 0.75rem;
		border-radius: 6px;
		transition: all 0.15s;
		font-family: 'Inter', sans-serif;
	}

	.nav-link:hover {
		color: var(--text);
		background: rgba(255, 255, 255, 0.03);
	}

	.nav-link--active {
		color: var(--accent);
		font-weight: 600;
	}

	.nav-link--external {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
	}

	/* Wallet button in nav */
	.nav-wallet {
		display: flex;
		align-items: center;
		margin-left: auto;
	}

	/* Mobile responsive */
	@media (max-width: 768px) {
		.main-nav {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
		}

		.nav-links {
			gap: 0.25rem;
			width: 100%;
		}

		.nav-link {
			font-size: 0.8rem;
			padding: 0.4rem 0.6rem;
		}

		.nav-wallet {
			margin-top: 0.5rem;
		}
	}
</style>
