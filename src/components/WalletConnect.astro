---
import { useAccount, useConnect, useDisconnect } from 'wagmi';
import { injected, walletConnect } from 'wagmi/connectors';

const styles = {
  container: {
    display: 'flex',
    gap: '0.5rem',
    alignItems: 'center',
  },
  button: {
    background: 'rgba(255, 107, 53, 0.1)',
    color: '#fff',
    border: '1px solid var(--border)',
    borderRadius: '8px',
    padding: '0.5rem 1rem',
    fontSize: '0.85rem',
    fontWeight: '600',
    cursor: 'pointer',
    transition: 'all 0.15s',
    display: 'flex',
    alignItems: 'center',
    gap: '0.5rem',
  },
  connected: {
    background: 'var(--accent)',
    borderColor: 'var(--accent)',
  },
};

export default function WalletConnect() {
  const { address, isConnected } = useAccount();
  const { connect, isPending } = useConnect();
  const { disconnect } = useDisconnect();

  if (isConnected && address) {
    return (
      <div style={styles.container} class="wallet-connected">
        <span style={{ ...styles.button, ...styles.connected }}>
          {address.slice(0, 6)}...{address.slice(-4)}
        </span>
        <button
          onClick={() => disconnect()}
          style={styles.button}
        >
          Disconnect
        </button>
      </div>
    );
  }

  return (
    <div style={styles.container}>
      <button
        style={styles.button}
        onClick={() => connect({ connector: injected() })}
        disabled={isPending}
      >
        {isPending ? 'Connecting...' : (
          <>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <path d="M20 12h-2.5a2.5 2.5 0 0-5 2.5l-1.6-1.6a2.5 2.5 0 0 2.5 4.9a4.9 4.9 0 0 0 5-2.5 2.5-2.5z" />
            </svg>
            <span>Connect</span>
          </>
        )}
      </button>
      <button
        style={styles.button}
        onClick={() => connect({ connector: coinbaseWallet({ app: { name: 'Suchbot' } }) })}
        disabled={isPending}
      >
        {isPending ? 'Connecting...' : (
          <>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <path d="M2.5 2.5h19a2.5 2.5 0 0 5 2.5 2.5 4.9a4.9 4.9 0 0 2.5 5-2.5 2.5h-19a2.5 2.5 0 0-5 2.5-2.5 4.9a4.9 4.9 0 0-5 2.5l2.5 2.5 0 0 0 2.5 5 2.5h-19a2.5 2.5z" />
            </svg>
            <span>Coinbase</span>
          </>
        )}
      </button>
    </div>
  );
}
