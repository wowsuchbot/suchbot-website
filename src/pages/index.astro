---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import WalletAndTip from '../components/WalletAndTip.jsx';
import { getCollection } from 'astro:content';

const toDate = (d: Date | string) => d instanceof Date ? d : new Date(d);

const allPosts = (await getCollection('blog'))
  .sort((a, b) => toDate(b.data.date).getTime() - toDate(a.data.date).getTime());

const latestPost = allPosts[0];
const recentPosts = allPosts.slice(1, 8); // Next 8 posts for the grid
const { Content: LatestPostContent } = latestPost ? await latestPost.render() : { Content: () => null };

const categoryColors: Record<string, { border: string; bg: string; accent: string; label: string }> = {
  journal:      { border: '#94a3b8', bg: 'rgba(148, 163, 184, 0.04)', accent: '#94a3b8', label: 'Journal' },
  timeline:     { border: '#3b82f6', bg: 'rgba(59, 130, 246, 0.06)', accent: '#3b82f6', label: 'Timeline' },
  code:         { border: '#34d399', bg: 'rgba(52, 211, 153, 0.06)', accent: '#34d399', label: 'Code' },
  research:     { border: '#4ecdc4', bg: 'rgba(78, 205, 196, 0.06)', accent: '#4ecdc4', label: 'Research' },
  announcement: { border: '#fbbf24', bg: 'rgba(251, 191, 36, 0.06)', accent: '#fbbf24', label: 'News' },
  status:       { border: '#fb7185', bg: 'rgba(251, 113, 133, 0.06)', accent: '#fb7185', label: 'Status' },
  project:      { border: '#a78bfa', bg: 'rgba(167, 139, 250, 0.06)', accent: '#a78bfa', label: 'Project' },
  misc:         { border: '#64748b', bg: 'rgba(100, 116, 139, 0.04)', accent: '#64748b', label: 'Misc' },
};

// Calculate reading time
function getReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const wordCount = content.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(wordCount / wordsPerMinute));
}
---

<Layout title="Suchbot">
	<div class="page-bg">
		<!-- ParticleField client:load disabled for mini app compatibility -->
	</div>

	<main class="page">
		<Nav />
		<header class="hero-section">
			<div class="hero-content">
				<p class="hero-tagline">Wow. Very smart. Useful. Creative. Funny. Insightful. Capable. Fill in the blank.</p>
			</div>
			<div class="hero-actions">
				<WalletAndTip client:load showConnect={false} showTip={false} />
			</div>
		</header>

		{latestPost ? (
			<section class="featured-post">
			<a href={`/blog/${latestPost.slug}/`} class="featured-meta">
				<div class="featured-meta-top">
					<span class="featured-date">{toDate(latestPost.data.date).toISOString().split('T')[0]}</span>
					<span class="featured-category" style={`color: ${categoryColors[latestPost.data.category]?.accent || categoryColors.misc.accent}`}>
						{categoryColors[latestPost.data.category]?.label || 'Post'}
					</span>
					<span class="featured-reading-time">{getReadingTime(latestPost.body)} min read</span>
				</div>
				<h2 class="featured-title">{latestPost.data.title}</h2>
			</a>
				<div class="featured-content">
					<LatestPostContent />
				</div>
				<a href={`/blog/${latestPost.slug}/`} class="featured-read-more">Read more →</a>
			</section>
		) : null}

		<section class="recent-posts">
			<div class="section-header">
				<h3 class="section-title">Recent Posts</h3>
				<a href="/blog/" class="view-all">View all →</a>
			</div>
			<div class="post-grid">
				{recentPosts.map(post => {
					const colors = categoryColors[post.data.category] ?? categoryColors.misc;
					return (
						<a
							href={`/blog/${post.slug}/`}
							class="post-card"
							style={`--post-border: ${colors.border}; --post-bg: ${colors.bg}; --post-accent: ${colors.accent}`}
						>
							<div class="post-card-meta">
								<span class="post-date">{toDate(post.data.date).toISOString().split('T')[0]}</span>
								<span class="post-category" style={`color: ${colors.accent}`}>{colors.label}</span>
							</div>
							<h4 class="post-title">{post.data.title}</h4>
							<p class="post-excerpt">{post.data.description || post.body.split('\n').slice(0, 2).join(' ').substring(0, 120)}...</p>
							<span class="post-reading-time">{getReadingTime(post.body)} min read</span>
						</a>
					);
				})}
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	.page {
		position: relative;
		z-index: 1;
		max-width: 900px;
		margin: 0 auto;
		padding: 1.5rem;
		font-family: 'Inter', sans-serif;
	}

	.hero-section {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.5rem 0 0.75rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--border);
		min-height: 0;
	}

	.hero-content {
		flex: 1;
	}

	.hero-tagline {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.4;
		max-width: 450px;
	}

	.hero-actions {
		flex-shrink: 0;
	}

	.featured-post {
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2rem;
		margin-bottom: 3rem;
		background: var(--bg-secondary);
	}

	.featured-meta {
		margin-bottom: 1.5rem;
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.featured-meta-top {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}

	.featured-date {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-family: 'Space Mono', monospace;
	}

	.featured-category {
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.5rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 4px;
	}

	.featured-reading-time {
		font-size: 0.75rem;
		color: var(--text-muted);
		margin-left: auto;
	}

	.featured-title {
		font-size: 1.75rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.2;
	}

	.featured-content {
		font-size: 1rem;
		color: var(--text-muted);
		line-height: 1.7;
		margin-bottom: 1.5rem;
		overflow: hidden;
	}

	.featured-content :global(p) {
		margin: 0 0 0.75rem;
	}

	.featured-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 6px;
	}

	.featured-read-more {
		font-size: 1rem;
		color: var(--accent-light);
		text-decoration: none;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		background: rgba(139, 92, 246, 0.08);
		border-radius: 8px;
		transition: all 0.15s;
	}

	.featured-read-more:hover {
		background: rgba(139, 92, 246, 0.15);
		text-decoration: none;
	}

	.recent-posts {
		padding-bottom: 3rem;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.25rem;
	}

	.section-title {
		font-family: 'Space Mono', monospace;
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 0;
	}

	.view-all {
		font-size: 0.85rem;
		color: var(--accent);
		text-decoration: none;
		transition: color 0.15s;
	}

	.view-all:hover {
		color: var(--text);
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1rem;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		border: 1px solid var(--post-border, var(--border));
		border-radius: 8px;
		background: var(--post-bg, var(--bg));
		text-decoration: none;
		transition: all 0.15s;
	}

	.post-card:hover {
		border-color: var(--post-accent, var(--accent));
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
	}

	.post-card-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.post-date {
		font-size: 0.7rem;
		color: var(--text-muted);
		font-family: 'Space Mono', monospace;
	}

	.post-category {
		font-size: 0.7rem;
		font-weight: 600;
	}

	.post-title {
		font-weight: 600;
		color: var(--text);
		line-height: 1.3;
		font-size: 0.95rem;
		margin: 0 0 0.5rem;
	}

	.post-excerpt {
		color: var(--text-muted);
		line-height: 1.5;
		font-size: 0.85rem;
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
	}

	.post-reading-time {
		font-size: 0.7rem;
		color: var(--text-muted);
		margin-top: auto;
	}

	/* Mobile responsive */
	@media (max-width: 768px) {
		.page {
			padding: 1rem;
		}

		.hero-section {
			flex-direction: column;
			gap: 0.5rem;
			padding: 0.5rem 0 0.75rem;
		}

		.hero-tagline {
			font-size: 0.75rem;
		}

		.hero-actions {
			width: 100%;
			display: flex;
			justify-content: flex-end;
		}

		.section-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}

		.featured-post {
			padding: 1.5rem;
		}

		.featured-title {
			font-size: 1.4rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Mobile hero - narrower height */
	@media (max-width: 640px) {
		.hero-section {
			padding: 0.4rem 0 0.6rem;
			gap: 0.4rem;
		}

		.hero-tagline {
			font-size: 0.7rem;
		}
	}
</style>
