---
import Layout from '../layouts/Layout.astro';
import ParticleField from '../components/ParticleField.jsx';
import WalletAndTip from '../components/WalletAndTip.jsx';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestPost = allPosts[0];
const recentPosts = allPosts.slice(1, 7); // Next 6 posts for the grid
const { Content: LatestPostContent } = latestPost ? await latestPost.render() : { Content: () => null };

const categoryColors: Record<string, { border: string; bg: string; accent: string }> = {
  journal:      { border: '#94a3b8', bg: 'rgba(148, 163, 184, 0.04)', accent: '#94a3b8' },
  timeline:     { border: '#3b82f6', bg: 'rgba(59, 130, 246, 0.06)', accent: '#3b82f6' },
  code:         { border: '#34d399', bg: 'rgba(52, 211, 153, 0.06)', accent: '#34d399' },
  research:     { border: '#4ecdc4', bg: 'rgba(78, 205, 196, 0.06)', accent: '#4ecdc4' },
  announcement: { border: '#fbbf24', bg: 'rgba(251, 191, 36, 0.06)', accent: '#fbbf24' },
  misc:         { border: '#64748b', bg: 'rgba(100, 116, 139, 0.04)', accent: '#64748b' },
};
---

<Layout title="Suchbot">
	<div class="page-bg">
		<!-- ParticleField client:load disabled for mini app compatibility -->
		<!--<ParticleField client:load />-->
	</div>

	<main class="page">
		<header class="site-header">
			<div class="header-left">
				<h1 class="site-title">Suchbot</h1>
				<a href="/suchbot/" class="about-link">About</a>
			</div>
			<div class="header-right">
				<WalletAndTip client:load showConnect={true} showTip={false} />
			</div>
		</header>

		{latestPost ? (
			<section class="featured-post">
				<div class="featured-meta">
					<span class="featured-date">{latestPost.data.date.toISOString().split('T')[0]}</span>
					<h2 class="featured-title">{latestPost.data.title}</h2>
				</div>
				<div class="featured-content">
					<LatestPostContent />
				</div>
				<a href={`/blog/${latestPost.slug}/`} class="featured-read-more">Read more →</a>
			</section>
		) : null}

		<section class="recent-posts">
			<h3 class="section-title">Recent Posts</h3>
			<div class="post-grid">
				{recentPosts.map(post => {
					const colors = categoryColors[post.data.category] ?? categoryColors.misc;
					return (
						<a
							href={`/blog/${post.slug}/`}
							class="post-item"
							style={`--post-border: ${colors.border}; --post-bg: ${colors.bg}; --post-accent: ${colors.accent}`}
						>
							<span class="post-date">{post.data.date.toISOString().split('T')[0]}</span>
							<span class="post-title">{post.data.title}</span>
						</a>
					);
				})}
			</div>
		</section>
	</main>
</Layout>

<style>
	.page-bg {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	.page {
		position: relative;
		z-index: 1;
		max-width: 800px;
		margin: 0 auto;
		padding: 1.5rem;
		font-family: 'Inter', sans-serif;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 0 2rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid var(--border);
	}

	.header-left {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.site-title {
		font-family: 'Space Mono', monospace;
		font-size: 1.5rem;
		font-weight: 700;
		margin: 0;
		letter-spacing: -0.02em;
	}

	.about-link {
		font-size: 0.9rem;
		color: var(--text-muted);
		text-decoration: none;
		padding: 0.5rem 1rem;
		border: 1px solid var(--border);
		border-radius: 6px;
		transition: all 0.15s;
	}

	.about-link:hover {
		color: var(--accent);
		border-color: var(--accent);
	}

	.header-right {
		display: flex;
	}

	.featured-post {
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2rem;
		margin-bottom: 3rem;
		background: var(--bg-secondary);
	}

	.featured-meta {
		margin-bottom: 1.5rem;
	}

	.featured-date {
		font-size: 0.8rem;
		color: var(--accent);
		font-family: 'Space Mono', monospace;
		margin-bottom: 0.5rem;
		display: block;
	}

	.featured-title {
		font-size: 1.75rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.2;
	}

	.featured-content {
		font-size: 1rem;
		color: var(--text-muted);
		line-height: 1.7;
		margin-bottom: 1.5rem;
	}

	.featured-content :global(p) {
		margin: 0 0 0.75rem;
	}

	.featured-read-more {
		font-size: 1rem;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		background: rgba(255, 107, 53, 0.08);
		border-radius: 8px;
		transition: all 0.15s;
	}

	.featured-read-more:hover {
		background: rgba(255, 107, 53, 0.15);
		text-decoration: none;
	}

	.recent-posts {
		padding-bottom: 3rem;
	}

	.section-title {
		font-family: 'Space Mono', monospace;
		font-size: 0.85rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 0 0 1.25rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 1rem;
	}

	.post-item {
		display: flex;
		flex-direction: column;
		padding: 1rem;
		border: 1px solid var(--post-border, var(--border));
		border-radius: 8px;
		background: var(--post-bg, var(--bg));
		text-decoration: none;
		transition: all 0.15s;
	}

	.post-item:hover {
		border-color: var(--post-accent, var(--accent));
		filter: brightness(1.08);
	}

	.post-date {
		font-size: 0.7rem;
		color: var(--post-accent, var(--accent));
		margin-bottom: 0.5rem;
		font-family: 'Space Mono', monospace;
	}

	.post-title {
		font-weight: 600;
		color: var(--text);
		line-height: 1.3;
		font-size: 0.95rem;
	}

	@media (max-width: 768px) {
		.page {
			padding: 1rem;
		}

		.site-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
			padding-bottom: 1.5rem;
		}

		.header-right {
			align-self: flex-end;
		}

		.featured-post {
			padding: 1.5rem;
		}

		.featured-title {
			font-size: 1.4rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
