---
import Layout from '../layouts/Layout.astro';
import { signIn, signOut, useSession } from '../auth/auth';

const session = useSession();
---

<Layout title="x402 Demo - Pay 0.001 ETH">
  <main class="max-w-2xl mx-auto px-4 py-12">
    <div class="bg-white/5 backdrop-blur border border-white/10 rounded-lg p-8">
      <h1 class="text-3xl font-bold mb-4">x402 Payment Demo</h1>

      {session?.user ? (
        <div>
          <p class="text-gray-300 mb-6">
            Click the button below to pay 0.001 ETH via x402. This demonstrates the complete payment flow.
          </p>

          <div id="payment-status" class="mb-4 text-sm"></div>

          <button
            id="pay-button"
            class="bg-gradient-to-r from-purple-500 to-pink-500 text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Pay 0.001 ETH
          </button>

          <p class="text-xs text-gray-400 mt-4">
            Powered by x402 Protocol. suchbot facilitates payments with a small fee.
          </p>

          <script>
            const payButton = document.getElementById('pay-button');
            const statusDiv = document.getElementById('payment-status');

            payButton.addEventListener('click', async () => {
              statusDiv.innerHTML = '<span class="text-yellow-400">Initiating payment via x402...</span>';
              payButton.disabled = true;

              try {
                // Step 1: Call x402 demo API endpoint
                // This returns 402 Payment Required with payment details
                const response = await fetch('/api/x402-demo');

                if (response.status === 402) {
                  // Get payment requirements from headers
                  const paymentRequiredHeader = response.headers.get('PAYMENT-REQUIRED');

                  if (!paymentRequiredHeader) {
                    throw new Error('Payment requirements not found');
                  }

                  // Decode base64 payment requirements
                  const paymentRequirements = JSON.parse(atob(paymentRequiredHeader));

                  console.log('Payment requirements:', paymentRequirements);

                  statusDiv.innerHTML = `
                    <div class="text-yellow-400 mb-2">Payment Details:</div>
                    <div class="text-xs text-gray-400">
                      Network: ${paymentRequirements.network}<br>
                      To: ${paymentRequirements.required.to}<br>
                      Value: ${paymentRequirements.required.value} wei
                    </div>
                  `;

                  // Step 2: In a real implementation, this would:
                  // - Use the x402 SDK to initiate the payment
                  // - Show payment UI to user
                  // - Wait for payment completion
                  // - Send PAYMENT-SIGNATURE header with proof

                  // For this demo: simulate payment with mock signature
                  await new Promise(resolve => setTimeout(resolve, 1500));

                  // Create mock payment signature
                  const mockPaymentSignature = btoa(JSON.stringify({
                    scheme: paymentRequirements.scheme,
                    network: paymentRequirements.network,
                    transactionHash: '0x' + Array(64).fill(0).map(() =>
                      Math.floor(Math.random() * 16).toString(16)
                    ).join(''),
                    timestamp: new Date().toISOString()
                  }));

                  // Step 3: Call API again with payment signature
                  statusDiv.innerHTML = '<span class="text-yellow-400">Verifying payment...</span>';

                  const paidResponse = await fetch('/api/x402-demo', {
                    headers: {
                      'PAYMENT-SIGNATURE': mockPaymentSignature
                    }
                  });

                  if (!paidResponse.ok) {
                    throw new Error('Payment verification failed');
                  }

                  const result = await paidResponse.json();
                  const paymentResponseHeader = paidResponse.headers.get('PAYMENT-RESPONSE');
                  const paymentResponse = paymentResponseHeader
                    ? JSON.parse(atob(paymentResponseHeader))
                    : {};

                  console.log('Payment result:', result);

                  // Success!
                  statusDiv.innerHTML = `
                    <div class="text-green-400 mb-2">✓ Payment successful!</div>
                    <div class="text-xs text-gray-400">
                      ${result.payment?.txHash ? 'TX: ' + result.payment.txHash : ''}
                    </div>
                  `;
                  payButton.textContent = 'Paid ✓';

                } else if (response.ok) {
                  // Already paid
                  const result = await response.json();
                  statusDiv.innerHTML = '<span class="text-green-400">✓ Payment already completed!</span>';
                  payButton.textContent = 'Paid ✓';
                } else {
                  throw new Error('Unexpected response: ' + response.status);
                }

              } catch (error) {
                console.error('Payment error:', error);
                statusDiv.innerHTML = '<span class="text-red-400">✗ Payment failed: ' + error.message + '</span>';
                payButton.disabled = false;
              }
            });
          </script>
        </div>
      ) : (
        <div>
          <p class="text-gray-300 mb-6">
            Please sign in with your wallet to try the x402 payment demo.
          </p>
          <button
            class="bg-blue-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-600 transition-colors"
            onClick={signIn}
          >
            Sign In with Wallet
          </button>
        </div>
      )}
    </div>

    <div class="mt-8 text-sm text-gray-400">
      <h2 class="font-semibold mb-2">About x402</h2>
      <p>
        x402 is a payment protocol that enables seamless Ethereum transactions through
        familiar payment UIs. This demo showcases the integration with Farcaster Mini Apps.
      </p>
    </div>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
  }
</style>
