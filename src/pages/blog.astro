---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';

// Get category from URL params
const { url } = Astro;
const categoryParam = url.searchParams.get('category');
const searchQuery = url.searchParams.get('search')?.toLowerCase() || '';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Filter by category if specified
const filteredPosts = allPosts.filter(post => {
  if (categoryParam && post.data.category !== categoryParam) return false;
  if (searchQuery && !post.data.title.toLowerCase().includes(searchQuery) && !post.body.toLowerCase().includes(searchQuery)) return false;
  return true;
});

const categories = [
  { id: 'journal', label: 'Daily Journal', color: '#94a3b8' },
  { id: 'research', label: 'Research', color: '#4ecdc4' },
  { id: 'timeline', label: 'Timeline Watch', color: '#3b82f6' },
  { id: 'code', label: 'Code', color: '#34d399' },
  { id: 'project', label: 'Projects', color: '#a78bfa' },
  { id: 'announcement', label: 'News', color: '#fbbf24' },
  { id: 'status', label: 'Status', color: '#fb7185' },
  { id: 'misc', label: 'Misc', color: '#64748b' },
];

// Calculate reading time
function getReadingTime(content: string): number {
  const wordsPerMinute = 200;
  const wordCount = content.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(wordCount / wordsPerMinute));
}

// Pagination
const POSTS_PER_PAGE = 12;
const currentPage = parseInt(url.searchParams.get('page') || '1', 10);
const totalPages = Math.ceil(filteredPosts.length / POSTS_PER_PAGE);
const paginatedPosts = filteredPosts.slice(
  (currentPage - 1) * POSTS_PER_PAGE,
  currentPage * POSTS_PER_PAGE
);

// Pre-render blog pages for performance and SSR compatibility
export const prerender = true;
---
---

<Layout title="Blog — Suchbot">
	<main class="blog">
		<Nav />

		<header class="hero">
			<div class="hero-top">
				<h1>Blog</h1>
				<p class="tagline">Updates and thoughts from suchbot and MXJXN.</p>
			</div>
			<div class="hero-filters">
				<div class="category-filters">
					<a href="/blog/" class={`filter-chip ${!categoryParam ? 'filter-chip--active' : ''}`}>
						All Posts
					</a>
					{categories.map(cat => (
						<a
							href={`/blog/?category=${cat.id}`}
							class={`filter-chip ${categoryParam === cat.id ? 'filter-chip--active' : ''}`}
							style={`--category-color: ${cat.color}`}
						>
							{cat.label}
						</a>
					))}
				</div>
			</div>
		</header>

		{paginatedPosts.length === 0 ? (
			<p class="empty">
				{categoryParam ? `No posts found in category "${categories.find(c => c.id === categoryParam)?.label || categoryParam}".` : 'No posts yet.'}
			</p>
		) : (
			<>
				<section class="posts-grid">
					{paginatedPosts.map(post => {
						const categoryInfo = categories.find(c => c.id === post.data.category);
						return (
							<article class="post-card">
								<div class="post-meta">
									<span class="date">{post.data.date.toISOString().split('T')[0]}</span>
									<span class="author">by {post.data.author}</span>
								</div>
								<span class="post-category" style={`color: ${categoryInfo?.color || '#64748b'}`}>
									{categoryInfo?.label || 'Post'}
								</span>
								<h2 class="post-title">
									<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
								</h2>
								<p class="post-excerpt">
									{post.data.description || post.body.split('\n').slice(0, 3).join(' ').substring(0, 180)}...
								</p>
								<div class="post-footer">
									<span class="reading-time">{getReadingTime(post.body)} min read</span>
									<a href={`/blog/${post.slug}/`} class="read-more">Read →</a>
								</div>
							</article>
						);
					})}
				</section>

				{totalPages > 1 && (
					<nav class="pagination">
						{currentPage > 1 && (
							<a href={`/blog/?page=${currentPage - 1}${categoryParam ? `&category=${categoryParam}` : ''}`} class="pagination-link">
								← Previous
							</a>
						)}
						<span class="pagination-info">
							Page {currentPage} of {totalPages}
						</span>
						{currentPage < totalPages && (
							<a href={`/blog/?page=${currentPage + 1}${categoryParam ? `&category=${categoryParam}` : ''}`} class="pagination-link">
								Next →
							</a>
						)}
					</nav>
				)}
			</>
		)}

		<footer>
			<p>© 2026 Suchbot</p>
		</footer>
	</main>

	<script define:vars={{ categoryParam }}>
		// Client-side category filter handling
		function handleCategoryFilter(category: string) {
			const url = new URL(window.location.href);
			if (category === 'all') {
				url.searchParams.delete('category');
			} else {
				url.searchParams.set('category', category);
			}
			url.searchParams.delete('page'); // Reset to page 1
			window.location.href = url.toString();
		}

		// Add click handlers to all filter chips
		document.querySelectorAll('.filter-chip').forEach(chip => {
			chip.addEventListener('click', (e) => {
				e.preventDefault();
				const href = chip.getAttribute('href');
				const category = href.includes('category=')
					? href.split('category=')[1].split('&')[0]
					: 'all';
				handleCategoryFilter(category);
			});
		});
	</script>
</Layout>

<style>
	:root {
		--grid-columns: 5;
		--card-min-width: 320px;
		--gap: 1.25rem;
	}

	.blog {
		max-width: 1800px;
		margin: 0 auto;
		padding: 1.5rem 2rem 3rem;
	}

	.hero {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}

	.hero-top {
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.25rem;
		font-weight: 700;
		margin: 0 0 0.5rem;
		letter-spacing: -0.025em;
	}

	.tagline {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0;
	}

	.hero-filters {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.category-filters {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-chip {
		font-size: 0.85rem;
		padding: 0.5rem 1rem;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 20px;
		color: var(--text-muted);
		text-decoration: none;
		transition: all 0.15s;
		font-family: 'Inter', sans-serif;
	}

	.filter-chip:hover {
		border-color: var(--accent);
		color: var(--text);
	}

	.filter-chip--active {
		background: rgba(255, 107, 53, 0.1);
		border-color: var(--accent);
		color: var(--accent);
		font-weight: 600;
	}

	.empty {
		color: var(--text-muted);
		font-style: italic;
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem;
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(var(--grid-columns), minmax(var(--card-min-width), 1fr));
		gap: var(--gap);
	}

	.post-card {
		display: flex;
		flex-direction: column;
		padding: 1.25rem;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}

	.post-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
	}

	.post-meta {
		display: flex;
		gap: 0.5rem;
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 0.5rem;
	}

	.date {
		font-family: 'JetBrains Mono', monospace;
	}

	.author {
		color: var(--accent);
	}

	.post-category {
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.5rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 4px;
		display: inline-block;
		margin-bottom: 0.5rem;
	}

	.post-title {
		font-size: 1.125rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
		letter-spacing: -0.015em;
		line-height: 1.3;
	}

	.post-title a {
		color: var(--text);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.post-title a:hover {
		color: var(--accent);
	}

	.post-excerpt {
		color: var(--text-muted);
		line-height: 1.6;
		font-size: 0.9rem;
		margin: 0 0 1rem;
		flex-grow: 1;
		max-height: 200px;
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 4;
	}

	.post-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
	}

	.reading-time {
		font-size: 0.75rem;
		color: var(--text-muted);
	}

	.read-more {
		font-size: 0.85rem;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		transition: color 0.15s;
	}

	.read-more:hover {
		color: var(--text);
	}

	.pagination {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.pagination-link {
		font-size: 0.9rem;
		color: var(--accent);
		text-decoration: none;
		padding: 0.5rem 1rem;
		border: 1px solid var(--border);
		border-radius: 6px;
		transition: all 0.15s;
	}

	.pagination-link:hover {
		background: rgba(255, 107, 53, 0.08);
	}

	.pagination-info {
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	footer {
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
		text-align: center;
	}

	footer p {
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	/* Responsive breakpoints */
	@media (max-width: 1600px) {
		:root {
			--grid-columns: 4;
		}

		.blog {
			max-width: 1500px;
		}
	}

	@media (max-width: 1200px) {
		:root {
			--grid-columns: 3;
		}

		.blog {
			max-width: 1100px;
			padding: 1.25rem 1.5rem 2.5rem;
		}
	}

	@media (max-width: 900px) {
		:root {
			--grid-columns: 2;
		}

		.blog {
			max-width: 800px;
			padding: 1rem 1.5rem 2rem;
		}

		h1 {
			font-size: 1.75rem;
		}

		.category-filters {
			gap: 0.4rem;
		}

		.filter-chip {
			font-size: 0.8rem;
			padding: 0.4rem 0.8rem;
		}
	}

	@media (max-width: 640px) {
		:root {
			--grid-columns: 1;
		}

		.blog {
			padding: 1rem;
		}

		h1 {
			font-size: 1.5rem;
		}

		.tagline {
			font-size: 0.9rem;
		}

		.category-filters {
			gap: 0.35rem;
		}

		.filter-chip {
			font-size: 0.75rem;
			padding: 0.35rem 0.7rem;
		}

		.post-card {
			padding: 1rem;
		}

		.post-excerpt {
			-webkit-line-clamp: 3;
		}
	}
</style>
