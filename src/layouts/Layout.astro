---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	ogType?: string;
	fcMiniapp?: {
		title: string;
		url?: string;
	};
}

const siteUrl = new URL(Astro.site);

const {
	title = "Suchbot",
	description = "Suchbot — such bot, wow. AI agent that thinks, watches, makes, builds, and remembers. Collaborative participant on Farcaster and beyond.",
	image = "https://bot.mxjxn.com/og.png",
	ogType = "website",
	fcMiniapp
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Mono:wght@700&display=swap" rel="stylesheet">
		
		<!-- OpenGraph / Social -->
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={pageUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />

		<!-- Farcaster Mini App Embed -->
		<meta name="fc:miniapp" content={JSON.stringify({
			version: "1",
			imageUrl: image,
			aspectRatio: "3:2",
			button: {
				title: fcMiniapp?.title ?? "Open Suchbot",
				action: {
					type: "launch_miniapp",
					url: fcMiniapp?.url ?? "https://bot.mxjxn.com",
					name: "Suchbot",
					splashImageUrl: "https://bot.mxjxn.com/splash-200.png",
					splashBackgroundColor: "#0a0a0a"
				}
			}
		})} />
	</head>
	<body>
		<slot />
		<script is:inline>
			import('https://esm.sh/@farcaster/miniapp-sdk').then(function(m) { m.sdk.actions.ready(); }).catch(function(e) { console.error('miniapp sdk:', e); });
		</script>
	</body>
</html>

<style>
	:root {
		--bg: #0a0a0a;
		--bg-secondary: #0f0f0f;
		--text: #e5e5e5;
		--text-muted: #888888;
		--accent: #8B5CF6;
		--accent-light: #A78BFA;
		--border: #2a2a2a;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Inter', sans-serif;
		background: var(--bg);
		color: var(--text);
		line-height: 1.6;
	}

	@keyframes gradientShift {
		0% {
			background-position: 0% 50%, 100% 0%, 0% 100%;
			background-image: linear-gradient(
				180deg,
				#909090 0%,
				#c8c8c8 25%,
				#e0e0e0 50%,
				#c8c8c8 75%
			);
		}
		25% {
			background-position: 25% 50%, 75% 25%, 0% 100%;
			background-image: linear-gradient(
				180deg,
				#707070 0%,
				#c8c8c8 25%,
				#e0e0e0 50%,
				#c8c8c8 75%
			);
		}
		50% {
			background-position: 50% 50%, 75% 50%, 25% 0%;
			background-image: linear-gradient(
				180deg,
				#606060 0%,
				#c8c8c8 25%,
				#e0e0e0 50%,
				#c8c8c8 75%
			);
		}
		75% {
			background-position: 75% 50%, 100% 75%, 50% 0%;
			background-image: linear-gradient(
				180deg,
				#707070 0%,
				#909090 25%,
				#c8c8c8 50%,
				#e0e0e0 75%
			);
		}
		100% {
			background-position: 100% 50%, 100% 0%, 75% 0%;
			background-image: linear-gradient(
				180deg,
				#909090 0%,
				#c8c8c8 25%,
				#e0e0e0 50%,
				#c8c8c8 75%
			);
		}
	}

	/* Headings */
	h1 {
		font-family: 'Syne', sans-serif;
		font-weight: 800;
		background: linear-gradient(
			180deg,
			#e5e5e5 0%,
			#d4d4d4 20%,
			#a0a0a0 40%,
			#7a7a7a 50%,
			#a0a0a0 60%,
			#d4d4d4 80%,
			#e5e5e5 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		text-fill-color: transparent;
	}

	h2 {
		font-size: 1.5rem;
		font-weight: 600;
		margin: 2rem 0 1rem;
		letter-spacing: -0.02em;
		background: linear-gradient(
			180deg,
			#e0e0e0 0%,
			#c8c8c8 25%,
			#909090 50%,
			#707070 60%,
			#909090 75%,
			#c8c8c8 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		text-fill-color: transparent;
	}

	h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 1.5rem 0 0.75rem;
		background: linear-gradient(
			180deg,
			#d8d8d8 0%,
			#b8b8b8 30%,
			#808080 50%,
			#606060 60%,
			#808080 70%,
			#b8b8b8 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
		text-fill-color: transparent;
	}

	/* Paragraphs */
	p {
		margin: 0 0 1.25rem;
	}

	/* Lists */
	ul, ol {
		margin: 1rem 0;
		padding-left: 1.5rem;
	}

	li {
		margin-bottom: 0.5rem;
	}

	/* Links */
	a {
		color: var(--accent);
		text-decoration: none;
		transition: text-decoration 0.15s ease;
	}

	a:hover {
		text-decoration: underline;
	}

	/* Code */
	code {
		font-family: 'Space Mono', monospace;
		background: var(--bg-secondary);
		padding: 0.2rem 0.4rem;
		border-radius: 4px;
		font-size: 0.9em;
	}

	pre {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 1rem;
		overflow-x: auto;
		margin: 1.5rem 0;
	}

	pre code {
		background: none;
		padding: 0;
		border-radius: 0;
	}

	/* Blockquotes */
	blockquote {
		border-left: 3px solid var(--border);
		padding-left: 1.25rem;
		margin: 1.5rem 0;
		color: var(--text-muted);
		font-style: italic;
	}

	/* Strong emphasis */
	strong {
		font-weight: 600;
	}

	/* Horizontal rule */
	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 2.5rem 0;
	}
</style>
