---
// Animated favicon with pulse to show suchbot is active/alive
// Subtle green glow when system is healthy
---

<a href="/" rel="icon" type="image/svg+xml">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32">
    <defs>
      <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#4ecdc4" stop-opacity="1" />
        <stop offset="100%" stop-color="#4ecdc4" stop-opacity="0" />
      </linearGradient>
      <filter id="glow-filter">
        <feGaussianBlur stdDeviation="2.5" result="blur" />
      </filter>
    </defs>

    <!-- Inner circle -->
    <circle cx="16" cy="16" r="12" fill="url(#glow)" opacity="0.6" />

    <!-- Outer glow ring -->
    <circle cx="16" cy="16" r="16" fill="none" stroke="url(#glow)" stroke-width="2" opacity="0.3" filter="url(#glow-filter)" />

    <!-- Core S - suchbot identity -->
    <circle cx="16" cy="16" r="7" fill="#0a0a0a" />
    <circle cx="12" cy="14" r="2.5" fill="#e5e5e5" opacity="0.8" />
    <circle cx="20" cy="14" r="2.5" fill="#e5e5e5" opacity="0.8" />

    <!-- Thinking indicator - subtle pulse -->
    <animate attributeName="opacity" values="0.6;0.9;0.6" dur="3s" repeatCount="indefinite" />
  </svg>
</a>
